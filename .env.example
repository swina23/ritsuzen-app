# このファイルをコピーして .env.local を作成してください
#   cp .env.example .env.local
# .env.local は .gitignore 済みのためコミットされません。

# アプリの版別。クラウド版(ritsuzen-app2)では 'cloud' を指定すると
# ヘッダーに「クラウド版」バッジが表示され、旧版と見分けられます。
# 旧版(ritsuzen-app)では未設定のままにしてください。
VITE_APP_VARIANT=cloud

# --- 以下は Step 1 (Firebase認証) で使用します。現時点では未使用 ---
# Firebase Console > プロジェクトの設定 > マイアプリ から取得した値を設定します。
# これらは秘密情報ではなく公開されて問題ない値です。
# アクセス制御は Firestore Security Rules で行います。
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

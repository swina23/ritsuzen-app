# このファイルをコピーして .env.local を作成してください
#   cp .env.example .env.local
# .env.local は .gitignore 済みのためコミットされません。

# アプリの版別。クラウド版(ritsuzen-app2)では 'cloud' を指定すると
# ヘッダーに「クラウド版」バッジが表示され、旧版と見分けられます。
# 旧版(ritsuzen-app)では未設定のままにしてください。
VITE_APP_VARIANT=cloud

# --- Firebase の設定値 ---
# Firebase Console > プロジェクトの設定 > マイアプリ から取得した値を設定します。
# これらは秘密情報ではなく、ビルド後のJSに埋め込まれて公開される値です。
# アクセス制御は Firestore Security Rules (firestore.rules) で行います。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
